# =============================================================================
# Marketplace — PRODUCTION Environment Variables (TEMPLATE)
# =============================================================================
# File ini di-commit sebagai template. Untuk pakai:
#   cp deployment/.env.production.example .env.production
#   nano .env.production    # isi semua nilai kosong
#
# File asli (.env.production) JANGAN di-commit (sudah di-ignore via
# deployment/.gitignore + root .gitignore).
#
# !!! PERINGATAN PRODUCTION !!!
# - JANGAN PERNAH jalankan `npx drizzle-kit push` atau `npx tsx src/seed.ts`
#   ke DB production. Lihat README bab 8.3 & 12.5.I:
#     - db:push  -> tidak buat migration file, tidak bisa rollback.
#     - seed.ts -> MENGHAPUS SEMUA DATA LAMA dulu sebelum insert sample.
#   Hanya jalankan: `npx drizzle-kit migrate` (apply migration SQL yang
#   sudah di-commit di packages/db/drizzle/).
# - Backup DB sebelum setiap migration: `pg_dump -U marketplace_production
#   -h localhost storefront_production > backup-$(date +%Y%m%d).sql`.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (bare-metal di VPS) — production DB
# -----------------------------------------------------------------------------
# Buat di VPS via `sudo -u postgres psql` (lihat README bab 12.5.H):
#   CREATE USER marketplace_production WITH PASSWORD 'ubah-password-kuat-production';
#   CREATE DATABASE storefront_production OWNER marketplace_production;
#
# DATABASE_URL adalah SATU-SATUNYA sumber koneksi yang dipakai oleh
# docker-compose.yml (anchor x-pg) dan drizzle-kit. PGUSER/PGPASS/PGDB di
# bawah HANYA referensi/dokumentasi — TIDAK dibaca oleh compose. Jadi kalau
# ubah credential, cukup update DATABASE_URL saja (pastikan URL-encode
# karakter special pada password: @ -> %40, : -> %3A, / -> %2F, # -> %23).
DATABASE_URL=postgresql://marketplace_production:ubah-password-kuat-production@host.docker.internal:5432/storefront_production
# Referensi saja (tidak dipakai oleh compose — edit DATABASE_URL jika ubah):
PGUSER=marketplace_production
PGPASS=ubah-password-kuat-production
PGDB=storefront_production

# -----------------------------------------------------------------------------
# Better Auth
# -----------------------------------------------------------------------------
# WAJIB identik untuk store & admin (sudah otomatis via compose). Hasilkan
# secret BARU untuk production (JANGAN reuse secret staging):
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# -----------------------------------------------------------------------------
# Google OAuth (Production)
# -----------------------------------------------------------------------------
# Redirect URI yang didaftarkan di Google Cloud Console (beda dari staging):
#   https://store.adfsport.cloud/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Email (SMTP production — JANGAN pakai Gmail App Password yang sama dgn staging)
# -----------------------------------------------------------------------------
# Untuk production, gunakan provider email khusus (SendGrid/Postmark/SES/
# Mailgun) dengan domain yang sudah di-verify, BUKAN Gmail App Password.
# Gmail App Password punya limit pengiriman dan bisa di-banned kalau volume
# tinggi — cocok untuk staging, tidak untuk production.
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Marketplace <noreply@yourdomain.com>

# -----------------------------------------------------------------------------
# Public app branding (build-time, di-inline ke client bundle)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=Marketplace

# -----------------------------------------------------------------------------
# Midtrans Payment (PRODUCTION — BUKAN sandbox)
# -----------------------------------------------------------------------------
# Ambil dari https://dashboard.midtrans.com/settings/config-info (dashboard
# PRODUCTION, bukan sandbox). Payment Notification URL di production dashboard:
#   https://store.adfsport.cloud/api/webhooks/midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=true
# Mode: "core" = QRIS direct via Core API (QR ditampilkan di app)
#       "snap" = redirect ke Midtrans Snap payment page
MIDTRANS_PAYMENT_MODE=snap