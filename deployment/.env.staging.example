# =============================================================================
# Marketplace — STAGING Environment Variables (TEMPLATE)
# =============================================================================
# File ini di-commit sebagai template. Untuk pakai:
#   cp deployment/.env.staging.example .env.staging
#   nano .env.staging    # isi semua nilai kosong
#
# File asli (.env.staging) JANGAN di-commit (sudah di-ignore).
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (bare-metal di VPS) — staging DB
# -----------------------------------------------------------------------------
# Buat di VPS via `sudo -u postgres psql` (lihat README bab 3.2 & 12.5.H):
#   CREATE USER marketplace_staging WITH PASSWORD 'ubah-password-kuat-staging';
#   CREATE DATABASE storefront_staging OWNER marketplace_staging;
#
# DATABASE_URL adalah SATU-SATUNYA sumber koneksi yang dipakai oleh
# docker-compose.yml (anchor x-pg) dan drizzle-kit. PGUSER/PGPASS/PGDB di
# bawah HANYA referensi/dokumentasi — TIDAK dibaca oleh compose. Jadi kalau
# ubah credential, cukup update DATABASE_URL saja (pastikan URL-encode
# karakter special pada password: @ -> %40, : -> %3A, / -> %2F, # -> %23).
DATABASE_URL=postgresql://marketplace_staging:ubah-password-kuat-staging@host.docker.internal:5432/storefront_staging
# Referensi saja (tidak dipakai oleh compose — edit DATABASE_URL jika ubah):
PGUSER=marketplace_staging
PGPASS=ubah-password-kuat-staging
PGDB=storefront_staging

# -----------------------------------------------------------------------------
# Better Auth
# -----------------------------------------------------------------------------
# WAJIB identik untuk store & admin (sudah otomatis via compose). Hasilkan
# secret baru dengan: openssl rand -base64 32
BETTER_AUTH_SECRET=
# BETTER_AUTH_URL di-override per-app di docker-compose.yml (dev-store / dev-admin),
# jadi tidak perlu di-set di sini.

# -----------------------------------------------------------------------------
# Google OAuth (Staging)
# -----------------------------------------------------------------------------
# Redirect URI yang didaftarkan di Google Cloud Console:
#   https://dev-store.adfsport.cloud/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Email (Gmail SMTP — App Password)
# -----------------------------------------------------------------------------
# Aktifkan 2-Step Verification, lalu buat App Password di
# https://myaccount.google.com/apppasswords — pakai 16-char itu, BUKAN
# password Google biasa.
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# -----------------------------------------------------------------------------
# Public app branding (build-time, di-inline ke client bundle)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=Marketplace Staging

# -----------------------------------------------------------------------------
# Midtrans Payment (SANDBOX untuk staging)
# -----------------------------------------------------------------------------
# Ambil dari https://dashboard.sandbox.midtrans.com/settings/config-info
# Payment Notification URL di sandbox dashboard:
#   https://dev-store.adfsport.cloud/api/webhooks/midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
# Mode: "core" = QRIS direct via Core API (QR ditampilkan di app)
#       "snap" = redirect ke Midtrans Snap payment page
MIDTRANS_PAYMENT_MODE=snap